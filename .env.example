# Copy to ".env" and fill in. The .env file is git-ignored.
# Only the variables for your selected provider (config.yaml -> provider) are needed.

# --- Gmail (use a Google App Password, not your account password) ---
GMAIL_USERNAME=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# --- Outlook / Office 365 ---
OUTLOOK_USERNAME=you@outlook.com
OUTLOOK_PASSWORD=

# --- SendGrid ---
SENDGRID_API_KEY=

# --- AWS SES ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Microsoft Graph ---
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_SENDER_USER_ID=

# --- Email verification (only if verification.strategy: api) ---
EMAIL_VERIFY_API_KEY=
